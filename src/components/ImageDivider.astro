---
import { Image } from 'astro:assets';
import testimonialBg from '../assets/images/testimonial-bg.png';
---

<section class="relative h-[400px] overflow-hidden" aria-hidden="true">
  <Image 
    src={testimonialBg}
    alt="High-end modern architectural interior detail"
    class="w-full h-full object-cover object-center"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-dark/70 mix-blend-multiply"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-dark/90 via-transparent to-dark/40"></div>
  
  <div class="absolute inset-0 flex items-center justify-center">
    <blockquote class="max-w-3xl mx-auto px-6 text-center relative z-10">
      <p class="text-2xl md:text-4xl font-heading text-white leading-relaxed italic font-light tracking-wide drop-shadow-lg">"Briana's team did our post-construction cleanup and I couldn't believe how thorough they were."</p>
      <cite class="text-white/80 text-sm md:text-base mt-6 block not-italic font-medium tracking-widest uppercase">— David L., General Contractor, Orem</cite>
    </blockquote>
  </div>
</section>
