---
---

<header class="fixed top-0 left-0 right-0 z-[9000] transition-all duration-300 bg-background shadow-sm border-b border-primary/10" id="navbar">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 md:h-24">
      
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 flex items-center group" aria-label="TML Property Services Home">
        <img 
          src="/images/tml-property-services-logo.png" 
          alt="TML Property Services Logo" 
          class="h-12 md:h-16 w-auto object-contain transition-transform group-hover:scale-105"
          width="200"
          height="48"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center space-x-8" aria-label="Main navigation">
        <div class="relative group h-full flex items-center py-8">
          <span class="text-sm font-medium text-dark hover:text-accent transition-colors flex items-center gap-1 cursor-default">
            Services
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:rotate-180"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </span>
          <div class="absolute top-full left-0 w-56 bg-background border border-primary/10 shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0 z-50">
            <a href="/services/commercial-cleaning" class="block px-6 py-4 text-sm font-medium text-dark hover:bg-primary/5 hover:text-accent border-b border-primary/5">Commercial Cleaning</a>
            <a href="/services/residential-cleaning" class="block px-6 py-4 text-sm font-medium text-dark hover:bg-primary/5 hover:text-accent border-b border-primary/5">Residential Cleaning</a>
            <a href="/services/move-in-move-out-cleaning" class="block px-6 py-4 text-sm font-medium text-dark hover:bg-primary/5 hover:text-accent border-b border-primary/5">Move-In / Move-Out</a>
            <a href="/services/post-construction-cleaning" class="block px-6 py-4 text-sm font-medium text-dark hover:bg-primary/5 hover:text-accent">Post-Construction</a>
          </div>
        </div>
        <a href="/about" class="text-sm font-medium text-dark hover:text-accent transition-colors">About</a>
        <a href="/service-areas/provo" class="text-sm font-medium text-dark hover:text-accent transition-colors">Service Areas</a>
        <a href="/#reviews" class="text-sm font-medium text-dark hover:text-accent transition-colors">Reviews</a>
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center space-x-6">
        <a href="/contact" class="btn-primary py-2 px-5 text-sm">
          Free Estimate
        </a>
      </div>

      <!-- Mobile: spacer to keep logo centered when nav is hidden -->
      <div class="md:hidden w-20" aria-hidden="true"></div>
    </div>
  </div>
</header>
