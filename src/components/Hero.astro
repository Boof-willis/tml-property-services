---
import { Image } from 'astro:assets';
import heroBg from '../assets/images/hero-bg.png';
import HeroAnimations from './HeroAnimations.jsx';
---

<section class="relative min-h-[100dvh] flex items-end pb-24 md:pb-32 overflow-hidden bg-background pt-32">
  <!-- Background Image with Gradient Overlay -->
  <div class="absolute inset-0 z-0">
    <Image 
      src={heroBg} 
      alt="Immaculate commercial office space in Utah County" 
      class="w-full h-full object-cover object-center -scale-x-100"
      fetchpriority="high"
      loading="eager"
    />
    <!-- Gradient Overlay: dark left fade for text readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-dark/90 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl" id="hero-content">
      
      <!-- Trust Signal -->
      <div class="inline-flex items-center gap-2 mb-6 hero-anim-item">
        <span class="flex gap-1">
          {[1,2,3,4,5].map(i => (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#ffffff" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </span>
        <span class="text-xs font-medium text-white/80 uppercase tracking-widest">5+ Years • Hundreds of Satisfied Clients</span>
      </div>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading text-white leading-[1.1] mb-6 hero-anim-item text-balance font-medium">
        Utah County's detail-oriented <br/>
        <span class="text-[#C4A265] italic font-light">commercial & residential</span><br/> 
        cleaning team.
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mb-10 font-light leading-relaxed hero-anim-item">
        From corporate offices to family homes, we bring obsessive attention to detail at competitive pricing. Flexible scheduling including nights and weekends to work around your life.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 hero-anim-item">
        <a href="#get-started" class="btn-primary w-full sm:w-auto">
          Get a Free Estimate
        </a>
        <a href="tel:8016354589" class="text-white/90 hover:text-white flex items-center gap-2 font-medium px-4 py-4 transition-colors">
          <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-sm border border-white/20 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          (801) 635-4589
        </a>
      </div>
    </div>
  </div>

  <HeroAnimations client:visible />
</section>