---
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark border-t border-background/10 text-background pt-20 pb-10 mt-auto" aria-label="Site Footer">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand & NAP -->
      <div class="space-y-6">
        <a href="/" class="inline-block" aria-label="TML Property Services Home">
          <img src="/images/tml-property-services-logo.png" alt="TML Property Services Logo" class="h-12 w-auto object-contain brightness-0 invert" />
        </a>
        <p class="text-background/70 font-light text-sm">
          Detail-oriented commercial and residential cleaning solutions serving Utah County and Salt Lake County.
        </p>
        <address class="not-italic text-sm text-background/80 space-y-2">
          <p>
            <a href="tel:8016354589" class="hover:text-accent transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (801) 635-4589
            </a>
          </p>
          <p>
            <a href="mailto:brianajean@thismessielife.com" class="hover:text-accent transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              brianajean@thismessielife.com
            </a>
          </p>
        </address>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-lg font-heading mb-6 text-background">Services</h4>
        <ul class="space-y-3 text-sm text-background/70">
          <li><a href="#services" class="hover:text-accent transition-colors">Commercial Cleaning</a></li>
          <li><a href="#services" class="hover:text-accent transition-colors">Office Maintenance</a></li>
          <li><a href="#services" class="hover:text-accent transition-colors">Residential Cleaning</a></li>
          <li><a href="#services" class="hover:text-accent transition-colors">Move-In/Move-Out</a></li>
          <li><a href="#services" class="hover:text-accent transition-colors">Post-Construction</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-lg font-heading mb-6 text-background">Company</h4>
        <ul class="space-y-3 text-sm text-background/70">
          <li><a href="#about" class="hover:text-accent transition-colors">About Us</a></li>
          <li><a href="#areas" class="hover:text-accent transition-colors">Service Areas</a></li>
          <li><a href="#reviews" class="hover:text-accent transition-colors">Testimonials</a></li>
          <li><a href="#faq" class="hover:text-accent transition-colors">FAQ</a></li>
          <li><a href="#get-started" class="hover:text-accent transition-colors">Get an Estimate</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-lg font-heading mb-6 text-background">Connect</h4>
        <div class="flex gap-4 mb-8">
          <a href="https://www.instagram.com/thismessielife/" target="_blank" rel="noopener noreferrer" class="text-background/70 hover:text-accent transition-colors" aria-label="Instagram">
