          </a>
        </div>
        <p class="text-sm text-background/70">Licensed, Bonded & Insured</p>
      </div>

    </div>

    <div class="border-t border-background/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-background/50">
      <p>&copy; {currentYear} TML Property Services. All rights reserved.</p>
      <div class="space-x-4">
        <a href="#" class="hover:text-background transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-background transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>