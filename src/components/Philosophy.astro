---
import { Image } from 'astro:assets';
import textureImg from '../assets/images/philosophy-texture.png';
import PhilosophyReveal from './PhilosophyReveal.jsx';
---

<section id="about" class="relative py-32 overflow-hidden bg-dark text-background" aria-label="Our Philosophy">
  <!-- Parallax Background Texture -->
  <div class="absolute inset-0 z-0 opacity-10">
    <Image 
      src={textureImg} 
      alt="Architectural texture" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-dark/80 mix-blend-multiply"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <span class="text-primary font-mono uppercase tracking-widest text-sm mb-6 block">Our Philosophy</span>
    
    <div class="text-3xl md:text-5xl lg:text-6xl font-heading leading-tight mb-12 font-medium">
      <PhilosophyReveal client:visible>
        I started cleaning homes in Nashville because it was the one thing that made chaos feel manageable. That turned into a company. That company taught me what detail-oriented really means — not as a marketing phrase, but as a standard. Every baseboard. Every light switch. Every corner someone thinks nobody notices. We notice.
      </PhilosophyReveal>
    </div>

    <p class="text-xl text-background/80 font-heading italic mb-10">
      — Briana Jean, Founder
    </p>

    <a href="/about" class="btn-primary">
      Read Our Story
    </a>
  </div>
</section>
