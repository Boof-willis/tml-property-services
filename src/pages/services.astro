---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Services | TML Property Services";
const description = "Comprehensive commercial and residential cleaning services in Utah County. Detail-oriented, flexible scheduling, and competitive pricing.";
---

<BaseLayout title={title} description={description} canonical="https://thismessielife.com/services">
  <div class="pt-32 pb-24 max-w-4xl mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-heading text-primary mb-6">Our Services</h1>
    <p class="text-lg text-dark/70 mb-12">Detail-oriented cleaning you can count on.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
      <div class="bg-white p-8 container-rounded shadow-sm border border-primary/5">
        <h2 class="text-2xl font-heading text-primary mb-4">Commercial Cleaning</h2>
        <p class="text-dark/70 mb-4">Office maintenance for SaaS companies, medical offices, and retail spaces. Flexible night and weekend scheduling available.</p>
        <a href="/services/commercial" class="text-accent font-medium hover:underline">Learn more &rarr;</a>
      </div>
      <div class="bg-white p-8 container-rounded shadow-sm border border-primary/5">
        <h2 class="text-2xl font-heading text-primary mb-4">Residential Cleaning</h2>
        <p class="text-dark/70 mb-4">Recurring deep cleans for homeowners who demand perfection. Flexible to your lifestyle.</p>
        <a href="/services/residential" class="text-accent font-medium hover:underline">Learn more &rarr;</a>
      </div>
      <div class="bg-white p-8 container-rounded shadow-sm border border-primary/5">
        <h2 class="text-2xl font-heading text-primary mb-4">Move-In / Move-Out</h2>
        <p class="text-dark/70 mb-4">Detailed sweeps to ensure properties are perfectly reset for the next tenant or owner.</p>
        <a href="/services/move" class="text-accent font-medium hover:underline">Learn more &rarr;</a>
      </div>
      <div class="bg-white p-8 container-rounded shadow-sm border border-primary/5">
        <h2 class="text-2xl font-heading text-primary mb-4">Post-Construction</h2>
        <p class="text-dark/70 mb-4">Thorough dust and debris removal for contractors and new builds. We make your finished project shine.</p>
        <a href="/services/post-construction" class="text-accent font-medium hover:underline">Learn more &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>