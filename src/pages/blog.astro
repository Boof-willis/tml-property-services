---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Blog | TML Property Services";
const description = "Cleaning tips, industry news, and updates from TML Property Services in Utah County.";
---

<BaseLayout title={title} description={description} canonical="https://thismessielife.com/blog">
  <div class="pt-32 pb-24 max-w-4xl mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-heading text-primary mb-6">Cleaning Insights</h1>
    <p class="text-lg text-dark/70">Check back soon for our latest articles, tips, and company updates.</p>
  </div>
</BaseLayout>