---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ContactForm from '../components/ContactForm.jsx';

const title = "Get a Free Estimate | TML Property Services";
const description = "Request a free on-site estimate for commercial or residential cleaning in Utah County. Call (801) 635-4589 or fill out our form.";
const canonical = "https://thismessielife.com/contact";

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Get a Free Estimate" }
];
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Hero -->
  <section class="pt-32 pb-16 bg-light">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={breadcrumbItems} />
      <h1 class="text-4xl md:text-6xl font-heading text-primary mb-6 text-balance">Get a Free Estimate</h1>
      <p class="text-lg md:text-xl text-dark/70 max-w-3xl font-light leading-relaxed">Tell us about your space and we'll schedule a free on-site walkthrough. No obligation, no pressure.</p>
    </div>
  </section>

  <!-- Form + Contact Info -->
  <section id="get-started" class="py-20 bg-background">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        
        <!-- Form -->
        <div class="lg:col-span-3">
          <ContactForm client:load />

          <!-- SSR Fallback (hidden once React hydrates) -->
          <noscript>
            <div class="bg-white text-dark p-8 md:p-10 shadow-xl border border-primary/10">
              <h3 class="text-2xl font-heading text-primary mb-6">Request an Estimate</h3>
              <form action="mailto:brianajean@thismessielife.com" method="POST" enctype="text/plain" class="space-y-6">
                <div>
                  <label class="block text-xs font-medium text-dark/80 mb-2 uppercase tracking-widest">Full Name</label>
                  <input type="text" name="name" required class="w-full px-4 py-4 bg-light border border-primary/10" placeholder="Jane Doe" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-dark/80 mb-2 uppercase tracking-widest">Phone Number</label>
                  <input type="tel" name="phone" required class="w-full px-4 py-4 bg-light border border-primary/10" placeholder="(801) 555-0123" />
                </div>
                <div>
                  <label class="block text-xs font-medium text-dark/80 mb-2 uppercase tracking-widest">Service Type</label>
                  <select name="service" class="w-full px-4 py-4 bg-light border border-primary/10">
                    <option value="Commercial Office">Commercial Cleaning</option>
                    <option value="Residential Home">Residential Cleaning</option>
                    <option value="Move-In / Move-Out">Move-In / Move-Out</option>
                    <option value="Post-Construction">Post-Construction</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-medium text-dark/80 mb-2 uppercase tracking-widest">Message (Optional)</label>
                  <textarea name="details" rows="3" class="w-full px-4 py-3 bg-light border border-primary/10 resize-none" placeholder="Tell us about your space..."></textarea>
                </div>
                <button type="submit" class="btn-primary w-full">Send Request</button>
              </form>
            </div>
          </noscript>
        </div>

        <!-- Contact Info Sidebar -->
        <aside class="lg:col-span-2 space-y-8">
          <div class="bg-white p-8 border border-primary/10">
            <h3 class="text-xl font-heading text-primary mb-6">Get in Touch</h3>
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-dark mb-1">Phone</p>
                  <a href="tel:8016354589" class="text-dark/70 hover:text-accent transition-colors">(801) 635-4589</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-dark mb-1">Email</p>
                  <a href="mailto:brianajean@thismessielife.com" class="text-dark/70 hover:text-accent transition-colors text-sm">brianajean@thismessielife.com</a>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white p-8 border border-primary/10">
            <h3 class="text-xl font-heading text-primary mb-4">What Happens Next</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 bg-accent/20 flex items-center justify-center text-accent text-xs font-bold shrink-0 mt-0.5">1</span>
                <p class="text-dark/70 text-sm font-light">We'll receive your request instantly and reach out via text and email.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 bg-accent/20 flex items-center justify-center text-accent text-xs font-bold shrink-0 mt-0.5">2</span>
                <p class="text-dark/70 text-sm font-light">A personal call follows to understand your specific needs.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="w-6 h-6 bg-accent/20 flex items-center justify-center text-accent text-xs font-bold shrink-0 mt-0.5">3</span>
                <p class="text-dark/70 text-sm font-light">We visit your property for a free, no-obligation walkthrough and custom quote.</p>
              </div>
            </div>
          </div>

          <div class="bg-white p-8 border border-primary/10">
            <h3 class="text-xl font-heading text-primary mb-4">Service Area</h3>
            <p class="text-dark/70 text-sm font-light mb-4">We serve Utah County and parts of Salt Lake County, including:</p>
            <div class="flex flex-wrap gap-2">
              {["Provo", "Orem", "Lehi", "American Fork", "Sandy", "Draper", "Springville", "Pleasant Grove"].map(city => (
                <span class="px-3 py-1 bg-light text-dark/70 text-xs border border-primary/10">{city}</span>
              ))}
            </div>
          </div>
        </aside>

      </div>
    </div>
  </section>

</BaseLayout>
